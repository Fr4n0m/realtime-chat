{
  "name": "realtime-chat",
  "private": false,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node --watch ./server/index.js\"",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview",
    "audit": "npm audit --omit=dev",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "concurrently": "9.0.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "main": "server/index.js",
  "dependencies": {
    "@supabase/supabase-js": "^2.99.1",
    "cors": "^2.8.5",
    "express": "^4.22.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.1",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1"
  },
  "author": "Fran1799",
  "license": "MIT",
  "description": "Real-time chat foundation with mock UI and production-ready server configuration"
}
